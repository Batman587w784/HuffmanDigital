<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Huffman Digital — Client Preview</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      background: #0d0d0d;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    }

    #hd-top, #hd-bottom, #hd-left, #hd-right {
      position: fixed;
      background: #0d0d0d;
      z-index: 9999;
    }

    #hd-top {
      top: 0; left: 0; right: 0;
      height: 90px;
      border-bottom: 1px solid #222;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
    }

    #hd-bottom {
      bottom: 0; left: 0; right: 0;
      height: 40px;
      border-top: 1px solid #222;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    #hd-left {
      top: 90px; bottom: 40px; left: 0;
      width: 40px;
      border-right: 1px solid #222;
    }

    #hd-right {
      top: 90px; bottom: 40px; right: 0;
      width: 40px;
      border-left: 1px solid #222;
    }

    /* ── iframe: inset on desktop, full on mobile ── */
    #hd-inner {
      position: fixed;
      top: 90px;
      bottom: 40px;
      left: 40px;
      right: 40px;
      z-index: 1;
      overflow: hidden;
      background: #fff;
    }

    /* Desktop: add inner padding so site floats inside the frame */
    @media (min-width: 768px) {
      #hd-inner {
        top: 102px;
        bottom: 52px;
        left: 52px;
        right: 52px;
        border-radius: 2px;
        box-shadow: 0 0 0 1px #1a1a1a;
      }
    }

    #hd-inner iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    /* Logo — bigger but inline so it doesn't push text */
    #hd-logo {
      display: block;
      height: 52px;
      width: auto;
      text-decoration: none;
      line-height: 0;
    }

    #hd-logo img {
      height: 100%;
      width: auto;
      display: block;
    }

    #hd-status {
      color: #ffffff;
      font-size: 10px;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      opacity: 0.4;
      margin-top: -2px;
    }

    #hd-cta {
      position: absolute;
      right: 28px;
      top: 50%;
      transform: translateY(-50%);
      color: #fff;
      font-size: 11px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      text-decoration: none;
      opacity: 0.45;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: opacity 0.15s;
    }
    #hd-cta:hover { opacity: 1; }
    #hd-cta:hover svg { transform: translateX(3px); }
    #hd-cta svg { transition: transform 0.15s; }

    #hd-bottom-text {
      color: #fff;
      font-size: 10px;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      opacity: 0.5;
    }

    #hd-bottom-text a {
      color: #fff;
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 1px;
      transition: border-color 0.15s;
    }
    #hd-bottom-text a:hover { border-color: #fff; }

    .hdot {
      width: 3px; height: 3px;
      border-radius: 50%;
      background: #333;
    }
  </style>
</head>
<body>

  <div id="hd-top">
    <a id="hd-logo" href="https://seanhuffman.com/digital" target="_blank" rel="noopener">
      <img src="data:image/png;base64," alt="Huffman Digital" />
    </a>
    <span id="hd-status">Client Design File &mdash; Work in Progress</span>
    <a id="hd-cta" href="https://seanhuffman.com/digital" target="_blank" rel="noopener">
      View our work
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2.5 6.5H10.5M7.5 3.5L10.5 6.5L7.5 9.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <div id="hd-left"></div>
  <div id="hd-right"></div>

  <div id="hd-inner">
    <iframe
      src="site.html"
      title="Client Site Preview"
      sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
    ></iframe>
  </div>

  <div id="hd-bottom">
    <div class="hdot"></div>
    <span id="hd-bottom-text">
      Property of Huffman Digital &mdash;
      <a href="https://seanhuffman.com/digital" target="_blank" rel="noopener">seanhuffman.com/digital</a>
    </span>
    <div class="hdot"></div>
  </div>

</body>
</html>
