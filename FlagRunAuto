<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flag Run Auto Body</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#c8251b;
  --red-mid:#e02d22;
  --red-light:#ff3b30;
  --black:#111111;
  --ink:#1a1a1a;
  --white:#ffffff;
  --off-white:#f8f7f5;
  --gray-1:#f0eeeb;
  --gray-2:#e0ddd8;
  --gray-3:#b0ada8;
  --gray-4:#6b6866;
  --text:#1a1a1a;
  --text-muted:#6b6866;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;color:var(--text);background:var(--white);overflow-x:hidden}

/* ─── UTIL ─── */
.container{max-width:1160px;margin:0 auto;padding:0 40px}
.tag{display:inline-block;font-size:11px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--red);margin-bottom:14px}
.serif{font-family:'DM Serif Display',serif}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}

/* ─── NAV ─── */
header{
  position:fixed;top:0;width:100%;z-index:200;
  background:rgba(255,255,255,0.97);
  border-bottom:1px solid var(--gray-2);
  backdrop-filter:blur(12px);
}
.nav{
  display:flex;align-items:center;justify-content:space-between;
  height:70px;
  max-width:1160px;margin:0 auto;padding:0 40px;
}
.logo{display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer}
.logo-mark{
  width:40px;height:40px;background:var(--red);
  display:flex;align-items:center;justify-content:center;
  font-family:'DM Serif Display',serif;font-size:17px;color:white;
  clip-path:polygon(8% 0%,92% 0%,100% 8%,100% 92%,92% 100%,8% 100%,0% 92%,0% 8%);
}
.logo-text{font-size:17px;font-weight:600;color:var(--black);letter-spacing:-0.2px}
.logo-text em{color:var(--red);font-style:normal}
nav ul{display:flex;list-style:none;gap:8px;align-items:center}
nav ul a{
  text-decoration:none;color:var(--text-muted);
  font-size:14px;font-weight:500;
  padding:8px 14px;border-radius:6px;
  transition:color .2s,background .2s;
}
nav ul a:hover,nav ul a.active{color:var(--black);background:var(--gray-1)}
.btn-estimate{
  background:var(--red);color:white;border:none;
  padding:10px 22px;border-radius:6px;
  font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;
  cursor:pointer;letter-spacing:.2px;transition:background .2s;
}
.btn-estimate:hover{background:var(--red-mid)}
.hamburger{display:none;background:none;border:none;cursor:pointer;padding:6px;flex-direction:column;gap:5px}
.hamburger span{display:block;width:24px;height:2px;background:var(--black);transition:.3s}
.mobile-nav{
  display:none;position:fixed;top:70px;left:0;right:0;bottom:0;
  background:white;z-index:199;padding:32px 40px;
  flex-direction:column;gap:4px;overflow-y:auto;
}
.mobile-nav.open{display:flex}
.mobile-nav a{
  text-decoration:none;color:var(--text);font-size:18px;font-weight:500;
  padding:14px 0;border-bottom:1px solid var(--gray-1);
}
.mobile-nav .btn-estimate{margin-top:20px;width:100%;text-align:center;padding:16px;font-size:15px}

/* ─── PAGES ─── */
.page{display:none;padding-top:70px;min-height:100vh}
.page.active{display:block}

/* ─── HOME ─── */
.hero{
  background:var(--black);
  padding:90px 0 80px;
  position:relative;overflow:hidden;
}
.hero::after{
  content:'';
  position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 80% at 80% 50%,rgba(200,37,27,0.12) 0%,transparent 65%);
  pointer-events:none;
}
.hero-inner{
  display:grid;grid-template-columns:1fr 1fr;gap:80px;
  align-items:center;
  max-width:1160px;margin:0 auto;padding:0 40px;
}
.hero-kicker{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(200,37,27,0.15);
  border:1px solid rgba(200,37,27,0.3);
  color:#ff6b63;font-size:11px;font-weight:600;letter-spacing:2px;
  text-transform:uppercase;padding:6px 14px;border-radius:100px;
  margin-bottom:28px;
}
.hero-kicker::before{content:'';width:6px;height:6px;background:#ff6b63;border-radius:50%}
.hero h1{
  font-family:'DM Serif Display',serif;
  font-size:clamp(46px,5.5vw,74px);
  line-height:1.05;color:white;
  letter-spacing:-1px;margin-bottom:24px;
}
.hero h1 em{color:var(--red-light);font-style:italic}
.hero-body{font-size:16px;color:#a8a5a0;line-height:1.75;max-width:420px;margin-bottom:36px}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:48px}
.btn-primary{
  background:var(--red);color:white;border:none;
  padding:14px 28px;border-radius:6px;
  font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;
  cursor:pointer;transition:background .2s,transform .15s;letter-spacing:.2px;
}
.btn-primary:hover{background:var(--red-mid);transform:translateY(-1px)}
.btn-outline-light{
  background:transparent;color:white;
  border:1px solid rgba(255,255,255,0.2);
  padding:14px 24px;border-radius:6px;
  font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;
  cursor:pointer;transition:border-color .2s,background .2s;
}
.btn-outline-light:hover{border-color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.05)}
.hero-trust{display:flex;flex-wrap:wrap;gap:20px}
.trust-pill{
  display:flex;align-items:center;gap:8px;
  font-size:12px;color:#888;font-weight:500;
}
.trust-pip{width:4px;height:4px;background:var(--red);border-radius:50%;flex-shrink:0}

/* hero right */
.hero-card{
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:16px;overflow:hidden;
}
.hero-card-img{
  aspect-ratio:4/3;background:rgba(255,255,255,0.04);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:12px;
  color:#555;font-size:13px;border-bottom:1px solid rgba(255,255,255,0.06);
}
.hero-card-img svg{opacity:.25}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr)}
.hero-stat{
  padding:20px 18px;text-align:center;
  border-right:1px solid rgba(255,255,255,0.06);
}
.hero-stat:last-child{border-right:none}
.stat-n{
  font-family:'DM Serif Display',serif;
  font-size:28px;color:white;letter-spacing:-0.5px;display:block
}
.stat-l{font-size:10px;color:#666;text-transform:uppercase;letter-spacing:1.5px;margin-top:2px}

/* marquee strip */
.strip{
  background:var(--red);padding:11px 0;
  overflow:hidden;white-space:nowrap;
}
.strip-track{
  display:inline-flex;gap:0;
  animation:marquee 25s linear infinite;
}
.strip-track:hover{animation-play-state:paused}
.strip-item{
  font-size:12px;font-weight:600;letter-spacing:2px;
  text-transform:uppercase;color:white;opacity:.9;
  padding:0 28px;
}
.strip-item::after{content:'·';margin-left:28px;opacity:.5}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* home sections */
.section{padding:96px 0}
.section-sm{padding:72px 0}
.section.bg-off{background:var(--off-white)}
.section.bg-black{background:var(--black)}
.section.bg-red{background:var(--red)}
.section-head{margin-bottom:56px}
.section-head h2{
  font-family:'DM Serif Display',serif;
  font-size:clamp(34px,3.5vw,50px);
  line-height:1.08;letter-spacing:-0.5px;
  margin-bottom:14px;
}
.section-head p{font-size:16px;color:var(--text-muted);line-height:1.7;max-width:520px}

/* services home */
.services-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--gray-2);border:1px solid var(--gray-2);border-radius:12px;overflow:hidden}
.svc-card{
  background:white;padding:36px 32px;
  position:relative;transition:background .25s;
}
.svc-card::before{
  content:'';position:absolute;top:0;left:0;width:3px;height:0;background:var(--red);
  transition:height .3s;
}
.svc-card:hover{background:var(--off-white)}
.svc-card:hover::before{height:100%}
.svc-icon{font-size:26px;margin-bottom:16px}
.svc-name{font-weight:600;font-size:16px;margin-bottom:8px}
.svc-desc{font-size:13px;color:var(--text-muted);line-height:1.6}

/* promise row */
.promise-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
.promise{text-align:center}
.promise-num{
  font-family:'DM Serif Display',serif;
  font-size:48px;color:var(--red);
  margin-bottom:8px;letter-spacing:-1px;
}
.promise-label{font-weight:600;font-size:14px;margin-bottom:6px}
.promise-sub{font-size:13px;color:var(--text-muted);line-height:1.5}

/* reviews home */
.reviews-row{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.review-card{
  border:1px solid var(--gray-2);border-radius:12px;
  padding:28px 26px;background:white;
}
.stars{color:var(--red);font-size:14px;letter-spacing:2px;margin-bottom:14px}
.review-text{font-size:14px;line-height:1.75;color:var(--text);margin-bottom:20px}
.reviewer{display:flex;align-items:center;gap:12px}
.avatar{
  width:38px;height:38px;border-radius:50%;
  background:var(--black);color:white;
  display:flex;align-items:center;justify-content:center;
  font-family:'DM Serif Display',serif;font-size:15px;
}
.rev-name{font-size:13px;font-weight:600}
.rev-context{font-size:12px;color:var(--text-muted)}

/* cta band */
.cta-band{
  background:var(--black);
  padding:80px 0;
  display:flex;align-items:center;
}
.cta-inner{
  max-width:1160px;margin:0 auto;padding:0 40px;
  display:flex;justify-content:space-between;align-items:center;gap:40px;
  flex-wrap:wrap;
}
.cta-inner h2{
  font-family:'DM Serif Display',serif;
  font-size:clamp(28px,3vw,42px);color:white;
  letter-spacing:-0.5px;max-width:480px;line-height:1.15;
}
.cta-inner h2 em{color:var(--red-light);font-style:italic}

/* ─── ABOUT PAGE ─── */
.page-hero{
  background:var(--off-white);
  border-bottom:1px solid var(--gray-2);
  padding:72px 0 64px;
}
.page-hero h1{
  font-family:'DM Serif Display',serif;
  font-size:clamp(38px,5vw,62px);
  letter-spacing:-1px;line-height:1.05;
  margin-bottom:16px;
}
.page-hero p{font-size:17px;color:var(--text-muted);max-width:520px;line-height:1.7}
.about-split{display:grid;grid-template-columns:1.1fr 1fr;gap:80px;align-items:start}
.about-copy h2{
  font-family:'DM Serif Display',serif;
  font-size:36px;letter-spacing:-0.5px;margin-bottom:16px;line-height:1.1;
}
.about-copy p{font-size:15px;color:var(--text-muted);line-height:1.8;margin-bottom:18px}
.checklist{list-style:none;margin-top:8px}
.checklist li{
  display:flex;align-items:flex-start;gap:12px;
  padding:12px 0;border-bottom:1px solid var(--gray-1);
  font-size:14px;
}
.checklist li:last-child{border-bottom:none}
.chk{
  width:20px;height:20px;background:var(--red);border-radius:4px;
  display:flex;align-items:center;justify-content:center;
  color:white;font-size:10px;font-weight:700;flex-shrink:0;margin-top:1px;
}
.about-aside{position:sticky;top:90px}
.aside-card{
  background:var(--off-white);border:1px solid var(--gray-2);
  border-radius:14px;padding:36px;margin-bottom:20px;
}
.aside-card h3{font-weight:600;font-size:16px;margin-bottom:6px}
.aside-card p{font-size:13px;color:var(--text-muted);line-height:1.65}
.aside-card .big{
  font-family:'DM Serif Display',serif;
  font-size:52px;color:var(--red);letter-spacing:-1px;margin-bottom:4px;
}
.cert-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:20px}
.cert-badge{
  background:white;border:1px solid var(--gray-2);
  border-radius:8px;padding:10px 14px;
  font-size:12px;font-weight:600;color:var(--text);
}
.team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.team-card{text-align:center}
.team-photo{
  aspect-ratio:3/2;background:var(--gray-1);
  border-radius:12px;margin-bottom:14px;
  display:flex;align-items:center;justify-content:center;
  font-size:36px;color:var(--gray-3);border:1px solid var(--gray-2);
}
.team-name{font-weight:600;font-size:15px;margin-bottom:4px}
.team-role{font-size:13px;color:var(--text-muted)}

/* ─── SERVICES PAGE ─── */
.services-full{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.svc-full{
  border:1px solid var(--gray-2);border-radius:14px;
  padding:40px 36px;background:white;position:relative;overflow:hidden;
  transition:border-color .25s,box-shadow .25s;
}
.svc-full:hover{border-color:var(--red);box-shadow:0 8px 32px rgba(200,37,27,.08)}
.svc-full-icon{font-size:32px;margin-bottom:20px}
.svc-full h3{font-family:'DM Serif Display',serif;font-size:24px;margin-bottom:10px;letter-spacing:-0.3px}
.svc-full p{font-size:14px;color:var(--text-muted);line-height:1.7;margin-bottom:20px}
.svc-full ul{list-style:none}
.svc-full ul li{
  font-size:13px;color:var(--text);padding:6px 0;
  border-bottom:1px solid var(--gray-1);
  display:flex;align-items:center;gap:8px;
}
.svc-full ul li:last-child{border-bottom:none}
.svc-full ul li::before{content:'→';color:var(--red);font-size:12px;font-weight:700}
.process-steps{counter-reset:step;display:flex;flex-direction:column;gap:0}
.step{
  display:flex;gap:24px;padding:28px 0;
  border-bottom:1px solid var(--gray-1);
}
.step:last-child{border-bottom:none}
.step-num{
  font-family:'DM Serif Display',serif;
  font-size:48px;color:var(--gray-2);
  line-height:1;flex-shrink:0;width:56px;
  letter-spacing:-1px;
}
.step-body h4{font-weight:600;font-size:16px;margin-bottom:6px}
.step-body p{font-size:14px;color:var(--text-muted);line-height:1.65}

/* ─── REVIEWS PAGE ─── */
.reviews-full{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.review-full{
  border:1px solid var(--gray-2);border-radius:12px;
  padding:32px;background:white;
}
.rating-bar{
  display:flex;align-items:center;gap:16px;
  padding:28px 32px;
  background:var(--off-white);border:1px solid var(--gray-2);
  border-radius:14px;margin-bottom:40px;
}
.rating-big{
  font-family:'DM Serif Display',serif;
  font-size:64px;color:var(--black);letter-spacing:-2px;flex-shrink:0;line-height:1;
}
.rating-right{}
.rating-stars{color:var(--red);font-size:22px;letter-spacing:3px;margin-bottom:6px}
.rating-count{font-size:13px;color:var(--text-muted)}

/* ─── CONTACT PAGE ─── */
.contact-layout{display:grid;grid-template-columns:1fr 1.4fr;gap:64px;align-items:start}
.contact-details{}
.contact-details h2{
  font-family:'DM Serif Display',serif;
  font-size:34px;margin-bottom:12px;letter-spacing:-0.5px;
}
.contact-details p{font-size:15px;color:var(--text-muted);line-height:1.7;margin-bottom:36px}
.contact-item{display:flex;gap:16px;margin-bottom:24px;align-items:flex-start}
.contact-icon{
  width:44px;height:44px;background:var(--off-white);
  border:1px solid var(--gray-2);border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
}
.contact-item-label{font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:var(--text-muted);font-weight:600;margin-bottom:3px}
.contact-item-val{font-size:15px;font-weight:500}
.hours-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:28px;padding-top:28px;border-top:1px solid var(--gray-2)}
.hour-row{display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px dashed var(--gray-2)}
.hour-row:last-child{border-bottom:none}
.hour-row span:last-child{color:var(--text-muted)}
.simple-form{background:var(--off-white);border:1px solid var(--gray-2);border-radius:16px;padding:44px}
.simple-form h3{font-family:'DM Serif Display',serif;font-size:28px;margin-bottom:6px;letter-spacing:-0.3px}
.simple-form > p{font-size:14px;color:var(--text-muted);margin-bottom:28px}
.field{margin-bottom:18px}
.field label{font-size:12px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:7px}
.field input,.field select,.field textarea{
  width:100%;background:white;
  border:1px solid var(--gray-2);border-radius:8px;
  font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);
  padding:12px 16px;outline:none;transition:border-color .2s;
}
.field input:focus,.field select,.field textarea:focus{border-color:var(--black)}
.field textarea{resize:vertical;min-height:100px}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}

/* ─── ESTIMATE MODAL ─── */
.overlay{
  display:none;position:fixed;inset:0;z-index:900;
  background:rgba(17,17,17,0.75);
  backdrop-filter:blur(8px);
  align-items:center;justify-content:center;
  padding:20px;
}
.overlay.open{display:flex}
.modal{
  background:white;border-radius:16px;
  width:100%;max-width:600px;
  max-height:92vh;overflow-y:auto;
  box-shadow:0 32px 80px rgba(0,0,0,.3);
}
.modal-head{
  position:sticky;top:0;background:white;z-index:1;
  padding:28px 36px 20px;
  border-bottom:1px solid var(--gray-2);
  display:flex;justify-content:space-between;align-items:flex-start;
}
.modal-head h2{font-family:'DM Serif Display',serif;font-size:26px;letter-spacing:-0.3px}
.modal-head h2 span{color:var(--red)}
.modal-head p{font-size:13px;color:var(--text-muted);margin-top:3px}
.modal-close{
  background:var(--gray-1);border:none;
  width:34px;height:34px;border-radius:8px;
  cursor:pointer;font-size:18px;
  display:flex;align-items:center;justify-content:center;
  transition:background .2s;flex-shrink:0;margin-top:2px;
}
.modal-close:hover{background:var(--gray-2)}
.modal-body{padding:28px 36px}

/* step progress */
.step-prog{display:flex;gap:0;margin-bottom:32px;border-radius:8px;overflow:hidden;border:1px solid var(--gray-2)}
.step-tab{
  flex:1;padding:11px 10px;text-align:center;
  font-size:11px;font-weight:600;letter-spacing:.5px;
  text-transform:uppercase;color:var(--text-muted);
  background:var(--gray-1);border-right:1px solid var(--gray-2);
  transition:background .2s,color .2s;cursor:default;
}
.step-tab:last-child{border-right:none}
.step-tab.done{background:var(--off-white);color:var(--text)}
.step-tab.active{background:var(--red);color:white}

.form-step{display:none}
.form-step.active{display:block}
.modal-foot{
  padding:0 36px 28px;
  display:flex;justify-content:space-between;align-items:center;
  gap:12px;
}
.btn-back{
  background:none;border:1px solid var(--gray-2);
  color:var(--text-muted);padding:11px 22px;border-radius:7px;
  font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;
  cursor:pointer;transition:.2s;
}
.btn-back:hover{color:var(--text);border-color:var(--black)}
.btn-next{
  background:var(--black);color:white;border:none;
  padding:12px 26px;border-radius:7px;
  font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;
  cursor:pointer;transition:background .2s;margin-left:auto;
}
.btn-next:hover{background:#2a2a2a}
.btn-submit-main{
  background:var(--red);color:white;border:none;
  padding:12px 28px;border-radius:7px;
  font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;
  cursor:pointer;transition:background .2s;margin-left:auto;
}
.btn-submit-main:hover{background:var(--red-mid)}
.upload-zone{
  border:2px dashed var(--gray-2);border-radius:10px;
  padding:28px 20px;text-align:center;cursor:pointer;
  background:var(--off-white);position:relative;
  transition:border-color .2s;
}
.upload-zone:hover{border-color:var(--black)}
.upload-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.upload-zone p{font-size:13px;color:var(--text-muted)}
.upload-zone strong{color:var(--text)}
.thumbs{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}
.thumbs img{width:72px;height:72px;object-fit:cover;border-radius:8px;border:1px solid var(--gray-2)}

/* success */
.success{display:none;text-align:center;padding:56px 36px}
.success.show{display:block}
.success-mark{font-size:52px;margin-bottom:16px}
.success h3{font-family:'DM Serif Display',serif;font-size:30px;margin-bottom:10px}
.success p{font-size:14px;color:var(--text-muted);line-height:1.7;max-width:360px;margin:0 auto 28px}
.success strong{color:var(--red)}

/* ─── FOOTER ─── */
footer{
  background:var(--ink);color:white;
  padding:64px 0 32px;
}
.footer-grid{
  display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:48px;
  margin-bottom:48px;
}
.footer-brand p{font-size:13px;color:#777;line-height:1.7;margin-top:12px;max-width:240px}
.footer-col h4{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#666;margin-bottom:16px}
.footer-col ul{list-style:none}
.footer-col li{margin-bottom:10px}
.footer-col a{text-decoration:none;color:#999;font-size:14px;transition:color .2s;cursor:pointer}
.footer-col a:hover{color:white}
.footer-bottom{
  border-top:1px solid #222;padding-top:24px;
  display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;
}
.footer-copy{font-size:12px;color:#555}
.footer-copy span{color:var(--red)}

