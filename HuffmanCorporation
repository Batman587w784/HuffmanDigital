<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Huffman Corporation — General Contractor, Bridgeport, WV</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy-deep:  #0a1628;
      --navy:       #0f2044;
      --navy-mid:   #163060;
      --navy-light: #1e4080;
      --white:      #ffffff;
      --grey-100:   #f4f6f9;
      --grey-200:   #e4e8ef;
      --grey-300:   #c8d0dc;
      --grey-400:   #8a96a8;
      --grey-500:   #5a6478;
      --grey-600:   #3a4255;
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--navy); overflow-x: hidden; line-height: 1.6; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--navy-deep); }
    ::-webkit-scrollbar-thumb { background: var(--navy-light); }

    /* ── CONTAINER ── */
    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2.5rem;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: 68px;
      background: var(--navy-deep);
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 2.5rem;
      height: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-left { display: flex; align-items: center; gap: 2.5rem; }
    .nav-logo { text-decoration: none; }
    .nav-logo-name {
      font-size: 0.9rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--white); display: block; line-height: 1;
    }
    .nav-logo-sub {
      font-size: 0.58rem; font-weight: 400; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--grey-400); margin-top: 3px; display: block;
    }
    .nav-divider { width: 1px; height: 26px; background: rgba(255,255,255,0.1); }
    .nav-links { display: flex; gap: 1.75rem; list-style: none; align-items: center; }
    .nav-links a {
      font-size: 0.7rem; font-weight: 500; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--grey-300); text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-phone {
      font-size: 0.78rem; font-weight: 600; color: var(--white);
      text-decoration: none; letter-spacing: 0.04em;
      border: 1px solid rgba(255,255,255,0.22); padding: 0.45rem 1.1rem;
      transition: background 0.2s;
    }
    .nav-phone:hover { background: rgba(255,255,255,0.07); }

    /* ── HERO ── */
    .hero {
      background-color: var(--navy-deep);
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
      background-size: 80px 80px, 80px 80px, 16px 16px, 16px 16px;
      background-position: -1px -1px, -1px -1px, -1px -1px, -1px -1px;
      padding-top: 68px;
      display: flex; align-items: center;
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 100% at 15% 50%, rgba(30,64,128,0.55) 0%, transparent 70%),
                  radial-gradient(ellipse 50% 80% at 90% 80%, rgba(15,32,68,0.8) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-inner {
      max-width: 1200px; margin: 0 auto; padding: 6.5rem 2.5rem;
      display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
      width: 100%; position: relative; z-index: 1;
    }
    .hero-eyebrow {
      font-size: 0.65rem; font-weight: 600; letter-spacing: 0.28em;
      text-transform: uppercase; color: var(--grey-400); margin-bottom: 1.5rem;
    }
    .hero-h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.6rem, 4.5vw, 3.8rem);
      line-height: 0.95; letter-spacing: 0.02em;
      color: var(--white); margin-bottom: 2rem;
    }
    .hero-h1 .accent { color: var(--grey-400); }
    .hero-desc {
      font-size: 0.93rem; font-weight: 300; line-height: 1.85;
      color: var(--grey-300); max-width: 40ch; margin-bottom: 1.75rem;
    }
    .hero-actions { display: flex; gap: 0.875rem; align-items: center; }
    .btn {
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.16em;
      text-transform: uppercase; text-decoration: none; padding: 0.85rem 1.75rem;
      transition: all 0.2s; display: inline-block; cursor: pointer; border: none; font-family: 'Inter', sans-serif;
    }
    .btn-white { background: var(--white); color: var(--navy-deep); }
    .btn-white:hover { background: var(--grey-200); }
    .btn-ghost { border: 1px solid rgba(255,255,255,0.28); color: var(--white); background: transparent; }
    .btn-ghost:hover { background: rgba(255,255,255,0.06); }

    .hero-stats {
      border-left: 1px solid rgba(255,255,255,0.1);
      padding-left: 4rem;
    }
    .hero-stat {
      padding: 1.1rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .hero-stat:first-child { border-top: 1px solid rgba(255,255,255,0.07); }
    .hero-stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.6rem; line-height: 1; color: var(--white); letter-spacing: 0.02em;
    }
    .hero-stat-label {
      font-size: 0.7rem; font-weight: 500; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--grey-400); margin-top: 0.3rem;
    }
    .hero-contact {
      margin-top: 1.25rem; padding-top: 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.07);
    }
    .hero-contact-label {
      font-size: 0.6rem; font-weight: 600; letter-spacing: 0.24em;
      text-transform: uppercase; color: var(--grey-400); margin-bottom: 0.5rem;
    }
    .hero-contact-phone {
      font-size: 1.25rem; font-weight: 700; color: var(--white);
      text-decoration: none; display: block; letter-spacing: -0.01em;
    }
    .hero-contact-addr {
      font-size: 0.78rem; color: var(--grey-400); margin-top: 0.4rem; font-weight: 300;
    }

    /* ── TRUST BAR ── */
    .trust-bar {
      background: var(--grey-100);
      border-top: 1px solid var(--grey-200);
      border-bottom: 1px solid var(--grey-200);
      padding: 1rem 0;
      overflow: hidden;
    }
    .trust-bar-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 2.5rem;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: nowrap; gap: 0; white-space: nowrap;
    }
    .trust-item {
      font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--grey-500);
      display: flex; align-items: center; gap: 0.45rem;
      flex-shrink: 0;
    }
    .trust-item::before {
      content: ''; width: 4px; height: 4px;
      background: var(--navy); border-radius: 50%; flex-shrink: 0;
    }

    /* ── SECTION WRAPPER ── */
    .section-wrap {
      padding: 4rem 0;
    }
    .section-wrap.bg-light { background: var(--grey-100); }
    .section-wrap.bg-dark { background: var(--navy-deep); }
    .section-wrap.bg-navy { background: var(--navy); }
    .section-wrap.bg-white { background: var(--white); }

    .section-overline {
      font-size: 0.62rem; font-weight: 600; letter-spacing: 0.3em;
      text-transform: uppercase; color: var(--grey-400);
      margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem;
    }
    .section-overline::before { content: ''; width: 20px; height: 1px; background: currentColor; }
    .section-overline.light { color: var(--grey-400); }
    .section-h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.4rem); line-height: 1;
      letter-spacing: 0.03em; color: var(--navy-deep); margin-bottom: 0.75rem;
    }
    .section-h2.light { color: var(--white); }
    .section-intro {
      font-size: 0.88rem; font-weight: 300; line-height: 1.8;
      color: var(--grey-600); max-width: 56ch; margin-bottom: 2.5rem;
    }
    .section-intro.light { color: var(--grey-300); }

    /* ── ABOUT ── */
    .about-grid {
      display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 5rem; align-items: start;
    }
    .about-body p {
      font-size: 0.93rem; font-weight: 300; line-height: 1.9; color: var(--grey-600);
      margin-bottom: 1.25rem;
    }
    .about-pull {
      border-left: 2px solid var(--navy); padding: 0.75rem 0 0.75rem 1.5rem;
      margin: 2rem 0;
    }
    .about-pull p {
      font-size: 0.95rem; font-weight: 500; line-height: 1.7;
      color: var(--navy-deep); margin: 0;
    }
    .stat-tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--grey-200); }
    .stat-tile { background: var(--white); padding: 1.75rem; }
    .stat-tile.dark { background: var(--navy-deep); }
    .stat-tile.span2 { grid-column: 1 / -1; }
    .stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.6rem; line-height: 1; color: var(--navy-deep); letter-spacing: 0.02em;
    }
    .stat-tile.dark .stat-num { color: var(--white); }
    .stat-label {
      font-size: 0.68rem; font-weight: 600; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--grey-400); margin-top: 0.4rem;
    }
    .stat-sub { font-size: 0.78rem; color: var(--grey-500); margin-top: 0.2rem; }
    .stat-tile.dark .stat-sub { color: var(--grey-300); }
    .stat-tile.dark .stat-label { color: var(--grey-400); }

    /* ── SERVICES ── */
    .services-grid {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 1px; background: rgba(255,255,255,0.06);
    }
    .service-card {
      background: var(--navy); padding: 2.75rem 2.25rem;
      transition: background 0.2s;
    }
    .service-card:hover { background: var(--navy-mid); }
    .service-index {
      font-size: 0.6rem; font-weight: 600; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--grey-500); margin-bottom: 1.75rem;
    }
    .service-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.55rem; letter-spacing: 0.04em; color: var(--white);
      line-height: 1; margin-bottom: 1.25rem;
    }
    .service-body {
      font-size: 0.84rem; font-weight: 300; line-height: 1.8; color: var(--grey-300);
      margin-bottom: 1.5rem;
    }
    .service-rule { width: 28px; height: 1px; background: rgba(255,255,255,0.18); margin-bottom: 1.5rem; }
    .service-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.45rem; }
    .service-bullets li {
      font-size: 0.78rem; color: var(--grey-400);
      padding-left: 1rem; position: relative;
    }
    .service-bullets li::before { content: '—'; position: absolute; left: 0; opacity: 0.4; }

    /* ── VIDEO ── */
    .video-container { max-width: 860px; }
    .video-embed {
      position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;
      background: var(--navy-deep);
    }
    .video-embed iframe {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;
    }
    .video-caption {
      font-size: 0.72rem; color: var(--grey-400); letter-spacing: 0.06em;
      margin-top: 0.85rem;
    }

    /* ── AREA ── */
    .counties-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(215px,1fr));
      gap: 1px; background: var(--grey-200);
    }
    .county-card { background: var(--white); padding: 1.6rem 1.75rem; transition: background 0.18s; }
    .county-card:hover { background: var(--grey-100); }
    .county-name {
      font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--navy); margin-bottom: 0.5rem;
    }
    .county-cities { font-size: 0.82rem; color: var(--grey-500); line-height: 1.7; font-weight: 300; }

    /* ── CONTACT ── */
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start;
    }
    .contact-details { display: flex; flex-direction: column; gap: 1.75rem; margin-top: 0.5rem; }
    .contact-row { display: flex; gap: 1.1rem; align-items: flex-start; }
    .contact-icon {
      width: 34px; height: 34px; flex-shrink: 0;
      border: 1px solid rgba(255,255,255,0.14);
      display: flex; align-items: center; justify-content: center; font-size: 0.85rem;
    }
    .contact-label {
      font-size: 0.6rem; font-weight: 600; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--grey-400); margin-bottom: 0.25rem;
    }
    .contact-val {
      font-size: 0.88rem; color: var(--white); font-weight: 300; line-height: 1.6;
    }
    .contact-val a { color: var(--white); text-decoration: none; }
    .contact-val a:hover { opacity: 0.7; }
    .form-head {
      font-size: 0.62rem; font-weight: 600; letter-spacing: 0.28em;
      text-transform: uppercase; color: var(--grey-400);
      padding-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 1.5rem;
    }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
    .field label {
      font-size: 0.62rem; font-weight: 600; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--grey-400);
    }
    .field input, .field select, .field textarea {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 0.72rem 1rem; font-size: 0.84rem; font-weight: 300;
      color: var(--white); font-family: 'Inter', sans-serif;
      outline: none; transition: border-color 0.2s; width: 100%;
    }
    .field input::placeholder, .field textarea::placeholder { color: var(--grey-500); }
    .field input:focus, .field select:focus, .field textarea:focus { border-color: rgba(255,255,255,0.35); }
    .field select option { background: var(--navy); }
    .field textarea { resize: vertical; min-height: 100px; }
    .form-submit {
      background: var(--white); color: var(--navy-deep); border: none;
      padding: 0.95rem 2rem; font-family: 'Inter', sans-serif;
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; cursor: pointer; transition: background 0.2s; width: 100%;
    }
    .form-submit:hover { background: var(--grey-200); }

    /* ── FOOTER ── */
    footer {
      background: var(--navy-deep);
      border-top: 1px solid rgba(255,255,255,0.07);
      padding: 1.75rem 0;
    }
    .footer-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 2.5rem;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 1rem;
    }
    .footer-logo {
      font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--white);
    }
    .footer-copy { font-size: 0.68rem; color: var(--grey-400); }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a {
      font-size: 0.65rem; color: var(--grey-400); text-decoration: none;
      letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--white); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-left > * { opacity: 0; animation: fadeUp 0.55s ease forwards; }
    .hero-left > *:nth-child(1) { animation-delay: 0.05s; }
    .hero-left > *:nth-child(2) { animation-delay: 0.15s; }
    .hero-left > *:nth-child(3) { animation-delay: 0.25s; }
    .hero-left > *:nth-child(4) { animation-delay: 0.35s; }
    .hero-stats { opacity: 0; animation: fadeUp 0.6s 0.2s ease forwards; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .hero-inner { grid-template-columns: 1fr; gap: 3rem; padding: 3rem 2.5rem; }
      .hero-stats { border-left: none; padding-left: 0; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2.5rem; }
      .about-grid { grid-template-columns: 1fr; gap: 3rem; }
      .services-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
      .form-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .section-wrap { padding: 4rem 0; }
      .stat-tiles { grid-template-columns: 1fr; }
      .stat-tile.span2 { grid-column: auto; }
    }
  </style>
</head>
