          <div class="stat-label">Build Methods</div>
          <div class="stat-sub">Mgmt, GC, Design-Build</div>
        </div>
        <div class="stat-tile">
          <div class="stat-num">7</div>
          <div class="stat-label">Counties Served</div>
          <div class="stat-sub">North Central WV</div>
        </div>
        <div class="stat-tile">
          <div class="stat-num">1</div>
