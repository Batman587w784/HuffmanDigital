<script>
// Intersection observer for reveals
const obs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if(e.isIntersecting) e.target.classList.add('on');
  });
},{threshold:0.1,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// Quote form
function handleQuote(e){
  e.preventDefault();
  const btn = e.target.querySelector('.form-submit');
  btn.innerHTML = '<svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none"><polyline points="20 6 9 17 4 12"/></svg> Request Received — We\'ll Be in Touch';
  btn.style.background = 'var(--blue2)';
  btn.style.cursor = 'default';
  e.target.querySelectorAll('input,select,textarea').forEach(i=>i.disabled=true);
}

// App form
function handleApp(e){
