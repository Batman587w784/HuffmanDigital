<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>West Virginia Green — Lawn Care & Pest Control Specialists</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px;scroll-padding-top:130px}
:root{
  --navy:    #0b1929;
  --navy2:   #0e2038;
  --navy3:   #122540;
  --blue:    #1a3a5c;
  --blue2:   #1e4976;
  --accent:  #2d7d4a;
  --accent2: #35a05e;
  --green-light: #4caf72;
  --sage:    #8ab89a;
  --cream:   #f5f2ec;
  --warm:    #e8e2d6;
  --off:     #d4cfc6;
  --muted:   #8a9db5;
  --white:   #ffffff;
  --border:  rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.14);
}
body{font-family:'Inter',sans-serif;background:var(--navy);color:var(--cream);overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
input,select,textarea,button{font-family:inherit}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--navy)}
::-webkit-scrollbar-thumb{background:var(--accent);border-radius:3px}

/* ── TOP BAR ── */
.topbar{
  background:var(--accent);
  padding:0.45rem 3rem;
  display:flex;align-items:center;justify-content:center;gap:2.5rem;
  font-size:0.76rem;font-weight:500;letter-spacing:0.04em;color:var(--white);
}
.topbar a{color:var(--white);transition:opacity 0.2s}
.topbar a:hover{opacity:0.75}
.topbar-sep{opacity:0.4}
@media(max-width:600px){.topbar{padding:0.45rem 1rem;gap:1.25rem;font-size:0.7rem}}

/* ── NAV ── */
nav{
  position:sticky;top:0;z-index:200;
  background:rgba(11,25,41,0.97);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  padding:0 3rem;
  display:flex;align-items:center;justify-content:space-between;
  height:130px;
}
.nav-brand{display:flex;align-items:center;gap:0;text-decoration:none}
.nav-logo-svg{height:44px;width:auto}
/* image utilities */
.img-cover{width:100%;height:100%;object-fit:cover;object-position:center;display:block}
/* video section */
.video-section{padding:3.5rem 0;background:var(--navy2)}
.video-wrap{position:relative;width:100%;max-width:820px;margin:2.5rem auto 0;padding-bottom:min(46.25%,380px);border-radius:3px;overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,0.5);border:1px solid var(--border)}
.video-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:none}
/* hero photo overlay */
.hero-photo-bg{position:absolute;inset:0;z-index:0}
.hero-photo-bg img{width:100%;height:100%;object-fit:cover;object-position:center 35%;filter:brightness(0.22) saturate(0.5)}
/* photo strip */
.photo-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:3px}
@media(max-width:640px){.photo-strip{grid-template-columns:1fr}}
.photo-strip-item{overflow:hidden;height:260px}
.photo-strip-item img{width:100%;height:100%;object-fit:cover;filter:brightness(0.72) saturate(0.75);transition:transform 0.6s ease,filter 0.4s ease}
.photo-strip-item:hover img{transform:scale(1.05);filter:brightness(0.85) saturate(0.9)}
/* split layout */
.split-section{display:grid;grid-template-columns:1fr 1fr}
@media(max-width:800px){.split-section{grid-template-columns:1fr}}
.split-img{position:relative;min-height:340px;overflow:hidden}
.split-img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(0.65) saturate(0.75)}
.split-content{display:flex;flex-direction:column;justify-content:center;padding:4rem 3rem;background:var(--navy2)}
@media(max-width:800px){.split-img{min-height:240px}.split-content{padding:3rem 1.5rem}}
.nav-links{list-style:none;display:flex;align-items:center;gap:0.25rem}
.nav-links a{
  font-size:0.78rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;
  color:var(--muted);padding:0.5rem 0.75rem;border-radius:3px;
  transition:color 0.2s,background 0.2s;
}
.nav-links a:hover{color:var(--white);background:rgba(255,255,255,0.05)}
.nav-quote{
  background:var(--accent);color:var(--white);
  font-size:0.75rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;
  padding:0.6rem 1.4rem;border-radius:2px;
  border:1px solid var(--accent);
  transition:background 0.2s,border-color 0.2s;
  cursor:pointer;
}
.nav-quote:hover{background:var(--accent2);border-color:var(--accent2)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
.hamburger span{width:22px;height:1.5px;background:var(--cream);display:block;transition:all 0.3s}
@media(max-width:900px){
  nav{padding:0 1.25rem}
  .nav-links{display:none;position:fixed;top:68px;left:0;right:0;bottom:0;
    background:rgba(11,25,41,0.99);flex-direction:column;align-items:center;justify-content:center;
    gap:2rem;z-index:199}
  .nav-links.open{display:flex}
  .nav-links a{font-size:1.1rem;letter-spacing:0.1em}
  .hamburger{display:flex}
  .nav-quote-wrap{display:none}
}

/* ── HERO ── */
.hero{
  position:relative;overflow:hidden;
  min-height:60vh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:3.5rem 2rem 3.5rem;
}
/* Gradient mesh background */
.hero-bg{
  position:absolute;inset:0;z-index:0;
  background:
    radial-gradient(ellipse 70% 50% at 50% 30%, rgba(26,58,92,0.9) 0%, transparent 70%),
    radial-gradient(ellipse 50% 60% at 20% 70%, rgba(45,125,74,0.35) 0%, transparent 55%),
    radial-gradient(ellipse 40% 50% at 80% 80%, rgba(30,73,118,0.4) 0%, transparent 55%),
    linear-gradient(170deg, #0b1929 0%, #0e2038 40%, #0a1f10 100%);
}
/* Grid overlay */
.hero-grid{
  position:absolute;inset:0;z-index:1;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}
/* Floating orbs */
.hero-orb1{
  position:absolute;width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle, rgba(45,125,74,0.15) 0%, transparent 70%);
  top:-100px;left:-100px;z-index:1;animation:drift 12s ease-in-out infinite;
}
.hero-orb2{
  position:absolute;width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle, rgba(26,58,92,0.25) 0%, transparent 70%);
  bottom:-150px;right:-150px;z-index:1;animation:drift 15s ease-in-out infinite reverse;
}
@keyframes drift{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,-30px)}}
.hero-content{position:relative;z-index:2;max-width:820px}
.hero-eyebrow{
  display:inline-block;
  font-size:0.72rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;
  color:var(--sage);margin-bottom:1.5rem;
  border-bottom:1px solid rgba(138,184,154,0.35);padding-bottom:0.5rem;
}
.hero h1{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(2.4rem,6vw,4.8rem);
  font-weight:600;line-height:1.0;letter-spacing:0.01em;
  color:var(--white);margin-bottom:1.5rem;
}
.hero h1 em{
  display:block;color:transparent;
  background:linear-gradient(135deg, var(--accent2) 0%, var(--sage) 100%);
  -webkit-background-clip:text;background-clip:text;
  font-style:normal;
}
.hero-sub{
  font-size:1rem;font-weight:300;line-height:1.8;
  color:var(--muted);max-width:540px;margin:0 auto 2.5rem;
}
.hero-actions{
  display:flex;flex-wrap:wrap;gap:0.85rem;justify-content:center;
}
.btn-primary{
  background:var(--accent);color:var(--white);
  font-size:0.8rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  padding:0.85rem 2rem;border-radius:2px;
  border:1px solid var(--accent);
  transition:all 0.25s;cursor:pointer;display:inline-flex;align-items:center;gap:0.5rem;
}
.btn-primary:hover{background:var(--accent2);border-color:var(--accent2);transform:translateY(-1px);box-shadow:0 8px 24px rgba(45,125,74,0.35)}
.btn-outline{
  background:transparent;color:var(--cream);
  font-size:0.8rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;
  padding:0.85rem 2rem;border-radius:2px;
  border:1px solid var(--border2);
  transition:all 0.25s;cursor:pointer;display:inline-flex;align-items:center;gap:0.5rem;
}
.btn-outline:hover{border-color:rgba(255,255,255,0.35);color:var(--white)}
.hero-trust{
  position:relative;z-index:2;
  margin-top:2rem;
  display:flex;flex-wrap:wrap;justify-content:center;gap:2.5rem;
}
.trust-item{
  text-align:center;
  font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);
}
.trust-num{
  display:block;
  font-family:'Cormorant Garamond',serif;
  font-size:1.8rem;font-weight:600;color:var(--white);line-height:1.1;margin-bottom:0.1rem;
}
.trust-sep{
  width:1px;background:var(--border);align-self:stretch;margin:0.5rem 0;
}
@media(max-width:600px){.trust-sep{display:none}.hero h1{font-size:2.8rem}}

/* ── SECTION COMMONS ── */
.section-inner{max-width:1100px;margin:0 auto;padding:0 2rem}
.section-eyebrow{
  font-size:0.7rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--sage);display:block;margin-bottom:0.9rem;
}
.section-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(2.2rem,5vw,3.6rem);font-weight:600;line-height:1.05;
  color:var(--white);
}
.section-title span{color:var(--accent2)}
.section-body{
  font-size:0.9rem;font-weight:300;line-height:1.85;
  color:var(--muted);max-width:560px;
}
.centered{text-align:center}
.centered .section-body{margin:0 auto}

/* ── HOW IT WORKS ── */
.howitworks{
  padding:4.5rem 0;
  background:var(--navy);
}
.steps-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
  margin-top:2rem;border:1px solid var(--border);
}
@media(max-width:900px){.steps-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.steps-grid{grid-template-columns:1fr}}
.step-card{
  padding:2.5rem 2rem;border-right:1px solid var(--border);
  position:relative;overflow:hidden;transition:background 0.3s;
}
.step-card:last-child{border-right:none}
@media(max-width:900px){.step-card:nth-child(2){border-right:none}.step-card:nth-child(3){border-top:1px solid var(--border)}.step-card:nth-child(4){border-top:1px solid var(--border);border-right:none}}
.step-card:hover{background:rgba(255,255,255,0.03)}
.step-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
  transform:scaleX(0);transform-origin:left;transition:transform 0.4s ease;
}
.step-card:hover::before{transform:scaleX(1)}
.step-n{
  font-family:'Cormorant Garamond',serif;
  font-size:3.5rem;font-weight:400;color:rgba(255,255,255,0.06);
  line-height:1;margin-bottom:1rem;
}
.step-card h4{
  font-size:0.85rem;font-weight:600;letter-spacing:0.04em;
  color:var(--white);margin-bottom:0.6rem;
}
.step-card p{font-size:0.8rem;color:var(--muted);line-height:1.7}
.step-icon{
  width:32px;height:32px;
  border:1px solid var(--accent);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:1.25rem;
}
.step-icon svg{width:14px;height:14px;stroke:var(--accent2);stroke-width:2;fill:none}

/* ── SERVICES ── */
.services{
  padding:4.5rem 0;
  background:linear-gradient(180deg, var(--navy) 0%, var(--navy2) 100%);
}
.svc-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
  margin-top:3.5rem;background:var(--border);
}
@media(max-width:900px){.svc-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.svc-grid{grid-template-columns:1fr}}
.svc-item{
  background:var(--navy2);padding:2.5rem 2rem;
  transition:background 0.25s;
  position:relative;
}
.svc-item:hover{background:var(--navy3)}
.svc-num{
  font-family:'Cormorant Garamond',serif;
  font-size:2.5rem;font-weight:400;color:rgba(255,255,255,0.06);
  line-height:1;margin-bottom:1rem;
}
.svc-item h3{
  font-size:0.92rem;font-weight:600;letter-spacing:0.02em;
  color:var(--white);margin-bottom:0.6rem;
}
.svc-item p{font-size:0.8rem;color:var(--muted);line-height:1.75;margin-bottom:1.25rem}
.svc-item a{
  font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--accent2);display:inline-flex;align-items:center;gap:0.35rem;
  transition:gap 0.2s;
}
.svc-item a:hover{gap:0.6rem}
.svc-dot{
  width:6px;height:6px;border-radius:50%;background:var(--accent2);
  position:absolute;top:2rem;right:2rem;
}

/* ── PROGRAMS / 7-ROUND ── */
.programs{
  padding:4.5rem 0;
  background:var(--navy3);
  position:relative;overflow:hidden;
}
.programs::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 100% 50%, rgba(45,125,74,0.1) 0%, transparent 60%),
    radial-gradient(ellipse 40% 60% at 0% 50%, rgba(26,58,92,0.2) 0%, transparent 55%);
  pointer-events:none;
}
.rounds-track{
  margin-top:3.5rem;
  display:flex;flex-direction:column;gap:0;
  border:1px solid var(--border);border-radius:3px;overflow:hidden;
}
.round-row{
  display:grid;grid-template-columns:220px 1fr;
  border-bottom:1px solid var(--border);
  transition:background 0.25s;
}
.round-row:last-child{border-bottom:none}
.round-row:hover{background:rgba(255,255,255,0.025)}
@media(max-width:700px){.round-row{grid-template-columns:1fr;}}
.round-season{
  padding:1.75rem 2rem;
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;justify-content:center;
  background:rgba(0,0,0,0.15);
}
@media(max-width:700px){.round-season{border-right:none;border-bottom:1px solid var(--border);padding:1.25rem 1.5rem}}
.round-label{
  font-size:0.68rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;
  color:var(--accent2);margin-bottom:0.3rem;
}
.round-name{
  font-family:'Cormorant Garamond',serif;
  font-size:1.2rem;font-weight:600;color:var(--white);line-height:1.2;
}
.round-details{
  padding:1.75rem 2rem;
  display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;
}
@media(max-width:700px){.round-details{padding:1.25rem 1.5rem}}
.round-tag{
  font-size:0.73rem;font-weight:500;
  background:rgba(45,125,74,0.12);
  border:1px solid rgba(45,125,74,0.25);
  color:var(--sage);
  padding:0.3rem 0.75rem;border-radius:2px;
  letter-spacing:0.02em;
}

/* ── ABOUT ── */
.about{
  padding:4.5rem 0;
  background:var(--cream);
}
.about-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;
}
@media(max-width:900px){.about-grid{grid-template-columns:1fr;gap:3rem}}
.about .section-eyebrow{color:var(--accent)}
.about .section-title{color:var(--navy)}
.about .section-title span{color:var(--accent)}
.about .section-body{color:#5a6e60}
.about-list{margin-top:2rem;display:flex;flex-direction:column;gap:1rem}
.about-item{
  display:flex;align-items:flex-start;gap:1rem;
  padding:1.25rem;
  background:var(--white);
  border-left:2px solid var(--accent);
  border-radius:0 2px 2px 0;
}
.about-item-icon{
  width:28px;height:28px;border-radius:50%;
  background:rgba(45,125,74,0.1);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;
}
.about-item-icon svg{width:13px;height:13px;stroke:var(--accent);stroke-width:2;fill:none}
.about-item h5{font-size:0.82rem;font-weight:600;color:var(--navy);margin-bottom:0.2rem}
.about-item p{font-size:0.78rem;color:#6b7a6b;line-height:1.6}
/* stat blocks */
.about-stats{
  display:grid;grid-template-columns:1fr 1fr;gap:1px;
  background:#d8d2c4;margin-top:0;
}
.about-stat{
  background:var(--white);padding:2rem 1.5rem;text-align:center;
}
.about-stat-num{
  font-family:'Cormorant Garamond',serif;
  font-size:3rem;font-weight:600;color:var(--navy);line-height:1;margin-bottom:0.3rem;
}
.about-stat-label{font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:#8a9d8a}
.about-pills{display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1.5rem}
.about-pill{
  font-size:0.72rem;font-weight:600;letter-spacing:0.06em;
  background:rgba(45,125,74,0.1);color:var(--accent);
  border:1px solid rgba(45,125,74,0.25);
  padding:0.3rem 0.8rem;border-radius:2px;
}

/* ── 14-POINT ANALYSIS ── */
.analysis{
  padding:4.5rem 0;
  background:linear-gradient(170deg, var(--navy2) 0%, #0d2010 100%);
}
.analysis-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
  background:var(--border);margin-top:3.5rem;
}
@media(max-width:900px){.analysis-grid{grid-template-columns:1fr 1fr}}
@media(max-width:480px){.analysis-grid{grid-template-columns:1fr}}
.analysis-item{
  background:rgba(14,32,56,0.6);
  padding:1.25rem 1.5rem;
  display:flex;align-items:center;gap:0.75rem;
  transition:background 0.2s;
}
.analysis-item:hover{background:rgba(14,32,56,0.9)}
.analysis-check{
  width:18px;height:18px;border-radius:50%;
  border:1px solid var(--accent2);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.analysis-check svg{width:9px;height:9px;stroke:var(--accent2);stroke-width:2.5;fill:none}
.analysis-item span{font-size:0.8rem;color:var(--cream);font-weight:400}

/* ── TESTIMONIALS ── */
.testimonials{
  padding:4.5rem 0;
  background:var(--navy);
}
.testi-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;
  margin-top:3.5rem;
}
@media(max-width:900px){.testi-grid{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.testi-grid{grid-template-columns:1fr}}
.testi-card{
  background:var(--navy2);
  border:1px solid var(--border);border-radius:3px;
  padding:2rem;
  transition:border-color 0.25s;
}
.testi-card:hover{border-color:rgba(53,160,94,0.3)}
.testi-stars{color:var(--accent2);font-size:0.8rem;letter-spacing:2px;margin-bottom:1rem}
.testi-card blockquote{
  font-family:'Cormorant Garamond',serif;
  font-size:1.05rem;font-style:italic;line-height:1.7;
  color:var(--cream);margin-bottom:1.5rem;
}
.testi-meta{font-size:0.75rem;color:var(--muted)}
.testi-meta strong{font-weight:600;color:var(--sage);text-transform:uppercase;letter-spacing:0.06em}

/* ── QUOTE CTA ── */
.quote-cta{
  padding:5rem 2rem;
  position:relative;overflow:hidden;
  background:linear-gradient(135deg, var(--navy3) 0%, var(--blue) 50%, var(--navy2) 100%);
  text-align:center;
}
/* Deep geometric pattern */
.quote-cta::before{
  content:'';position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);
  background-size:40px 40px;
}
.quote-cta::after{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 80% at 50% 50%, rgba(45,125,74,0.2) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 20% 20%, rgba(30,73,118,0.35) 0%, transparent 50%),
